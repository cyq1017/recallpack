    "executionManifest41": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "manifest_version",
        "created_at",
        "descope_rung",
        "semantic_rules_version",
        "code_hashes",
        "scenario_slots",
        "evidence_scenarios",
        "fixture_hashes",
        "label_hashes",
        "hidden_test_hashes",
        "variants",
        "provider_settings",
        "comparison_contract",
        "evaluator_contract",
        "technical_failure_codes",
        "execution_order",
        "input_artifact_catalog",
        "claim_declarations",
        "review",
        "evaluator_image_digest"
      ],
      "properties": {
        "record_type": {"const": "execution_manifest"},
        "manifest_version": {"const": "execution-manifest/4.1"},
        "created_at": {"$ref": "#/$defs/timestamp"},
        "descope_rung": {"enum": ["Full", "R1", "R2"]},
        "semantic_rules_version": {"const": "4.1"},
        "code_hashes": {"$ref": "#/$defs/codeHashes41"},
        "scenario_slots": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/scenarioSlot"}
        },
        "evidence_scenarios": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": {"$ref": "#/$defs/evidenceScenario41"}
        },
        "fixture_hashes": {"$ref": "evaluation.schema.json#/$defs/hashMap"},
        "label_hashes": {"$ref": "evaluation.schema.json#/$defs/hashMap"},
        "hidden_test_hashes": {"$ref": "evaluation.schema.json#/$defs/hashMap"},
        "variants": {
          "type": "array",
          "prefixItems": [
            {"const": "raw_full_history"},
            {"const": "semantic_rerank"},
            {"const": "recency_aware"},
            {"const": "recall_time_resolver"},
            {"const": "recallpack"}
          ],
          "items": false
        },
        "provider_settings": {"$ref": "evaluation.schema.json#/$defs/providerSettings"},
        "comparison_contract": {"$ref": "#/$defs/comparisonContract41"},
        "evaluator_contract": {"$ref": "evaluation.schema.json#/$defs/evaluatorContract"},
        "technical_failure_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "evaluation.schema.json#/$defs/technicalFailureCode"}
        },
        "execution_order": {
          "type": "array",
          "minItems": 30,
          "items": {"$ref": "evaluation.schema.json#/$defs/executionSlot"}
        },
        "input_artifact_catalog": {"$ref": "#/$defs/inputArtifactCatalog41"},
        "claim_declarations": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "evaluation.schema.json#/$defs/claimDeclaration"}
        },
        "review": {"$ref": "#/$defs/review41"},
        "evaluator_image_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      },
      "allOf": [
        {
          "if": {"properties": {"descope_rung": {"const": "Full"}}},
          "then": {
            "properties": {
              "scenario_slots": {"minItems": 4, "maxItems": 4},
              "evidence_scenarios": {"minItems": 4, "maxItems": 4},
              "execution_order": {"minItems": 60, "maxItems": 60}
            }
          }
        },
        {
          "if": {"properties": {"descope_rung": {"const": "R1"}}},
          "then": {
            "properties": {
              "scenario_slots": {"minItems": 3, "maxItems": 3},
              "evidence_scenarios": {"minItems": 3, "maxItems": 3},
              "execution_order": {"minItems": 45, "maxItems": 45}
            }
          }
        },
        {
          "if": {"properties": {"descope_rung": {"const": "R2"}}},
          "then": {
            "properties": {
              "scenario_slots": {"minItems": 2, "maxItems": 2},
              "evidence_scenarios": {"minItems": 2, "maxItems": 2},
              "execution_order": {"minItems": 30, "maxItems": 30}
            }
          }
        }
      ]
    }
  }
