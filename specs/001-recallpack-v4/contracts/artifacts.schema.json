{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recallpack.local/schemas/v4/artifacts.schema.json",
  "title": "RecallPack V4 Compile Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "semantic_rules_version",
    "compile_id",
    "pack",
    "pack_markdown",
    "trace",
    "files"
  ],
  "properties": {
    "schema_version": {"const": "4.0"},
    "semantic_rules_version": {"const": "compile-semantic-rules/4.0"},
    "compile_id": {"type": "string", "pattern": "^cmp_[A-Za-z0-9]+$"},
    "pack": {"$ref": "#/$defs/pack"},
    "pack_markdown": {"type": "string", "minLength": 1},
    "trace": {"$ref": "#/$defs/trace"},
    "files": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "allOf": [
            {"$ref": "#/$defs/file"},
            {"properties": {"name": {"const": "recallpack.json"}}}
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/file"},
            {"properties": {"name": {"const": "PACK.md"}}}
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/file"},
            {"properties": {"name": {"const": "trace.json"}}}
          ]
        }
      ],
      "items": false
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+:[A-Za-z0-9._-]+$"
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memories"],
      "properties": {
        "memories": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "subject", "text", "scope", "source_ref"],
            "properties": {
              "id": {"type": "string"},
              "type": {"enum": ["decision", "preference", "lesson"]},
              "subject": {"type": "string"},
              "text": {"type": "string"},
              "scope": {"type": "string"},
              "source_ref": {"$ref": "#/$defs/sourceRef"}
            }
          }
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compile_id",
        "request",
        "memory_snapshot_seq",
        "candidate_scores",
        "reranked_memory_ids",
        "selected_memory_ids",
        "omissions",
        "exact_token_count",
        "tokenizer",
        "provider_traces",
        "runtime_steps",
        "input_artifact_hashes"
      ],
      "properties": {
        "compile_id": {"type": "string", "pattern": "^cmp_[A-Za-z0-9]+$"},
        "request": {
          "type": "object",
          "additionalProperties": false,
          "required": ["project_id", "goal", "component", "budget_tokens"],
          "properties": {
            "project_id": {"type": "string", "minLength": 1},
            "goal": {"type": "string", "minLength": 1},
            "component": {"type": "string", "minLength": 1},
            "budget_tokens": {"type": "integer", "minimum": 1, "maximum": 512}
          }
        },
        "memory_snapshot_seq": {"type": "integer", "minimum": 0},
        "candidate_scores": {
          "type": "array",
          "maxItems": 20,
          "items": {"$ref": "#/$defs/candidateScore"}
        },
        "reranked_memory_ids": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "selected_memory_ids": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "omissions": {
          "type": "array",
          "items": {"$ref": "#/$defs/omission"}
        },
        "exact_token_count": {"type": "integer", "minimum": 0, "maximum": 512},
        "tokenizer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["encoding", "package", "package_version", "exact"],
          "properties": {
            "encoding": {"const": "o200k_base"},
            "package": {"const": "tiktoken"},
            "package_version": {"const": "0.13.0"},
            "exact": {"const": true}
          }
        },
        "provider_traces": {
          "type": "array",
          "minItems": 0,
          "maxItems": 2,
          "items": {"$ref": "#/$defs/providerTrace"}
        },
        "runtime_steps": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "prefixItems": [
            {
              "allOf": [
                {"$ref": "#/$defs/runtimeStep"},
                {"properties": {"index": {"const": 0}, "name": {"const": "validate_request"}, "deterministic": {"const": true}}}
              ]
            },
            {
              "allOf": [
                {"$ref": "#/$defs/runtimeStep"},
                {"properties": {"index": {"const": 1}, "name": {"const": "load_active_snapshot"}, "deterministic": {"const": true}}}
              ]
            },
            {
              "allOf": [
                {"$ref": "#/$defs/runtimeStep"},
                {"properties": {"index": {"const": 2}, "name": {"const": "embedding_top_20"}, "deterministic": {"const": false}}}
              ]
            },
            {
              "allOf": [
                {"$ref": "#/$defs/runtimeStep"},
                {"properties": {"index": {"const": 3}, "name": {"const": "rerank"}, "deterministic": {"const": false}}}
              ]
            },
            {
              "allOf": [
                {"$ref": "#/$defs/runtimeStep"},
                {"properties": {"index": {"const": 4}, "name": {"const": "budget_select"}, "deterministic": {"const": true}}}
              ]
            },
            {
              "allOf": [
                {"$ref": "#/$defs/runtimeStep"},
                {"properties": {"index": {"const": 5}, "name": {"const": "render_artifacts"}, "deterministic": {"const": true}}}
              ]
            },
            {
              "allOf": [
                {"$ref": "#/$defs/runtimeStep"},
                {"properties": {"index": {"const": 6}, "name": {"const": "publish_artifacts"}, "deterministic": {"const": true}}}
              ]
            }
          ],
          "items": false
        },
        "input_artifact_hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["recallpack.json", "PACK.md"],
          "properties": {
            "recallpack.json": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "PACK.md": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        }
      }
    },
    "candidateScore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory_id",
        "candidate_index",
        "embedding_cosine",
        "rerank_score",
        "source_project_event_seq",
        "lifecycle_status",
        "scope",
        "source_ref"
      ],
      "properties": {
        "memory_id": {"type": "string", "minLength": 1},
        "candidate_index": {"type": "integer", "minimum": 0, "maximum": 19},
        "embedding_cosine": {"type": "number", "minimum": -1, "maximum": 1},
        "rerank_score": {"type": ["number", "null"]},
        "source_project_event_seq": {"type": "integer", "minimum": 1},
        "lifecycle_status": {"const": "active"},
        "scope": {"type": "string", "minLength": 1},
        "source_ref": {"$ref": "#/$defs/sourceRef"}
      }
    },
    "omission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memory_id", "stage", "reason"],
      "properties": {
        "memory_id": {"type": "string", "minLength": 1},
        "stage": {"enum": ["embedding", "rerank", "budget"]},
        "reason": {
          "enum": ["outside_top_20", "rerank_order", "budget_overflow", "not_selected"]
        }
      }
    },
    "providerTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "provider_family",
        "model_name",
        "request_purpose",
        "input_item_count",
        "input_token_estimate",
        "output_item_count",
        "live",
        "deterministic_fallback",
        "request_id_present",
        "token_usage"
      ],
      "properties": {
        "role": {"enum": ["embedding", "rerank"]},
        "provider_family": {"enum": ["qwen_cloud", "deterministic_fake"]},
        "model_name": {"type": "string", "minLength": 1},
        "request_purpose": {"type": "string", "minLength": 1},
        "input_item_count": {"type": "integer", "minimum": 0},
        "input_token_estimate": {"type": "integer", "minimum": 0},
        "output_item_count": {"type": "integer", "minimum": 0},
        "latency_ms": {"type": "integer", "minimum": 0},
        "live": {"type": "boolean"},
        "deterministic_fallback": {"type": "boolean"},
        "request_id_present": {"type": "boolean"},
        "token_usage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input_tokens", "output_tokens", "total_tokens", "reported_by_provider"],
          "properties": {
            "input_tokens": {"type": "integer", "minimum": 0},
            "output_tokens": {"type": "integer", "minimum": 0},
            "total_tokens": {"type": "integer", "minimum": 0},
            "reported_by_provider": {"type": "boolean"}
          }
        }
      }
    },
    "runtimeStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "name", "status", "duration_ms", "deterministic"],
      "properties": {
        "index": {"type": "integer", "minimum": 0},
        "name": {
          "enum": [
            "validate_request",
            "load_active_snapshot",
            "embedding_top_20",
            "rerank",
            "budget_select",
            "render_artifacts",
            "publish_artifacts"
          ]
        },
        "status": {"enum": ["succeeded", "skipped"]},
        "duration_ms": {"type": "integer", "minimum": 0},
        "deterministic": {"type": "boolean"}
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256", "bytes"],
      "properties": {
        "name": {"enum": ["recallpack.json", "PACK.md", "trace.json"]},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "bytes": {"type": "integer", "minimum": 0}
      }
    }
  }
}
